{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(bun install)",
      "Bash(bun run validate)",
      "Bash(bun run sync)",
      "Bash(bun run catalog)",
      "Bash(bun run zip)",
      "Bash(bun run build)",
      "Bash(bun run test)",
      "Bash(bun run typecheck)",
      "Bash(bun run lint)",
      "Bash(bun run lint:md)",
      "Bash(bun run lint:md:fix)",
      "Bash(bun run check)",
      "Bash(bun run format)",
      "Read(**)"
    ],
    "deny": [
      "Write(node_modules/**)",
      "Write(dist/**)",
      "Write(.turbo/**)"
    ]
  }
}
