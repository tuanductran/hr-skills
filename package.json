{
	"name": "hr-skills",
	"version": "1.0.1",
	"private": true,
	"description": "AI skills and technical recruiting knowledge for modern HR and talent acquisition teams.",
	"type": "module",
	"packageManager": "bun@1.3.9",
	"author": "Tuan Duc Tran",
	"license": "MIT",
	"homepage": "https://github.com/tuanductran/hr-skills#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tuanductran/hr-skills.git"
	},
	"bugs": {
		"url": "https://github.com/tuanductran/hr-skills/issues"
	},
	"keywords": [
		"hr",
		"human-resources",
		"skills",
		"ai-skills",
		"claude",
		"llm",
		"agents",
		"recruiting",
		"performance-management",
		"compliance"
	],
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"test": "turbo run test",
		"typecheck": "turbo run typecheck",
		"clean": "bun scripts/clean.ts",
		"check": "biome check .",
		"lint": "biome check . --write",
		"format": "biome format . --write",
		"lint:md": "markdownlint . && case-police .",
		"lint:md:fix": "markdownlint . --fix && case-police . --fix",
		"lint:links": "markdown-link-check -c config.json ./content ./docs ./examples ./skills",
		"knip": "knip",
		"sync": "turbo run sync --filter=hr-skills-build",
		"catalog": "turbo run catalog --filter=hr-skills-build",
		"validate": "turbo run validate --filter=hr-skills-build",
		"zip": "bun scripts/zip.ts",
		"release": "changelogen --release --patch --push",
		"prepare": "lefthook install",
		"preinstall": "bunx only-allow bun",
		"commitlint": "commitlint --edit"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@commitlint/cli": "^21.0.2",
		"@commitlint/config-conventional": "^21.0.2",
		"@commitlint/types": "^21.0.1",
		"@types/bun": "^1.3.14",
		"case-police": "^2.2.1",
		"changelogen": "^0.6.2",
		"knip": "^6.15.0",
		"lefthook": "^2.1.9",
		"markdown-link-check": "^3.14.2",
		"markdownlint-cli": "^0.48.0",
		"turbo": "^2.9.16",
		"typescript": "^6.0.3"
	}
}
