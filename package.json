{
	"name": "hr-skills",
	"version": "1.0.0",
	"packageManager": "bun@1.3.9",
	"type": "module",
	"private": true,
	"description": "A collection of 15 HR AI skills for Claude — covering recruiting, performance management, compliance, analytics, and all major HR domains.",
	"author": "Tuan Duc Tran",
	"license": "MIT",
	"homepage": "https://github.com/tuanductran/hr-skills#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tuanductran/hr-skills.git"
	},
	"bugs": {
		"url": "https://github.com/tuanductran/hr-skills/issues"
	},
	"keywords": [
		"hr",
		"human-resources",
		"skills",
		"ai-skills",
		"claude",
		"llm",
		"agents",
		"recruiting",
		"performance-management",
		"compliance"
	],
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "turbo run build",
		"test": "turbo run test",
		"typecheck": "turbo run typecheck",
		"check": "biome check .",
		"lint": "biome check . --write",
		"format": "biome format . --write",
		"validate": "turbo run validate --filter=hr-skills-build",
		"catalog": "turbo run catalog --filter=hr-skills-build",
		"sync": "turbo run sync --filter=hr-skills-build",
		"lint:md": "markdownlint --ignore-path=.gitignore '**/*.md' && case-police '**/*.md'",
		"lint:md:fix": "markdownlint --ignore-path=.gitignore '**/*.md' --fix && case-police '**/*.md' --fix",
		"lint:links": "markdown-link-check -c config.json ./skills",
		"zip": "bun scripts/zip.ts",
		"commitlint": "commitlint --edit",
		"knip": "knip",
		"prepare": "lefthook install",
		"preinstall": "bunx only-allow bun"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@commitlint/cli": "^21.0.1",
		"@commitlint/config-conventional": "^21.0.1",
		"@types/bun": "^1.3.14",
		"case-police": "^2.2.1",
		"knip": "^6.14.1",
		"lefthook": "^2.1.8",
		"markdown-link-check": "^3.14.2",
		"markdownlint-cli": "^0.48.0",
		"turbo": "^2.9.14",
		"typescript": "^6.0.3"
	}
}
