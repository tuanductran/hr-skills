{
	"name": "hr-skills",
	"version": "1.0.3",
	"private": true,
	"description": "AI skills and technical recruiting knowledge for modern HR and talent acquisition teams.",
	"type": "module",
	"packageManager": "bun@1.3.14",
	"author": "Tuan Duc Tran",
	"license": "MIT",
	"homepage": "https://github.com/tuanductran/hr-skills#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tuanductran/hr-skills.git"
	},
	"bugs": {
		"url": "https://github.com/tuanductran/hr-skills/issues"
	},
	"keywords": [
		"hr",
		"human-resources",
		"skills",
		"ai-skills",
		"claude",
		"llm",
		"agents",
		"recruiting",
		"performance-management",
		"compliance"
	],
	"workspaces": {
		"packages": [
			"packages/*"
		],
		"catalog": {
			"@clack/prompts": "^1.7.0",
			"@types/bun": "^1.3.14",
			"knip": "^6.26.0",
			"valibot": "^1.4.2",
			"tsdown": "^0.22.3",
			"turbo": "^2.10.4",
			"typescript": "^6.0.3",
			"yaml": "^2.9.0"
		},
		"catalogs": {
			"biome": {
				"@biomejs/biome": "^2.5.3"
			},
			"commit": {
				"@commitlint/cli": "^21.2.1",
				"@commitlint/config-conventional": "^21.2.0",
				"@commitlint/types": "^21.2.0",
				"changelogen": "^0.6.2",
				"lefthook": "^2.1.10"
			},
			"markdown": {
				"case-police": "^2.2.1",
				"markdown-link-check": "^3.14.2",
				"markdownlint-cli": "^0.49.0"
			}
		}
	},
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"test": "turbo run test",
		"typecheck": "turbo run typecheck",
		"check": "biome check .",
		"lint": "biome check . --write",
		"format": "biome format . --write",
		"lint:md": "markdownlint . && case-police .",
		"lint:md:fix": "markdownlint . --fix && case-police . --fix",
		"lint:links": "markdown-link-check -c config.json ./docs ./skills",
		"knip": "knip",
		"sync": "turbo run sync --filter=hr-skills-build",
		"validate": "turbo run validate --filter=hr-skills-build",
		"release": "changelogen --release --patch --push",
		"prepare": "lefthook install",
		"preinstall": "bunx only-allow bun",
		"commitlint": "commitlint --edit"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:biome",
		"@commitlint/cli": "catalog:commit",
		"@commitlint/config-conventional": "catalog:commit",
		"@commitlint/types": "catalog:commit",
		"@types/bun": "catalog:",
		"case-police": "catalog:markdown",
		"changelogen": "catalog:commit",
		"knip": "catalog:",
		"lefthook": "catalog:commit",
		"markdown-link-check": "catalog:markdown",
		"markdownlint-cli": "catalog:markdown",
		"turbo": "catalog:",
		"typescript": "catalog:"
	}
}
