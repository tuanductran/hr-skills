{
	"compilerOptions": {
		"target": "ESNext",
		"lib": ["ESNext"],
		"moduleDetection": "force",
		"module": "Preserve",
		"moduleResolution": "bundler",
		"types": ["bun"],
		"strict": true,
		"noFallthroughCasesInSwitch": true,
		"noEmit": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": true
	},
	"include": ["src/**/*", "test/**/*"],
	"exclude": ["node_modules"]
}
