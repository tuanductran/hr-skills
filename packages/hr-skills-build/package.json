{
	"name": "hr-skills-build",
	"version": "0.0.0",
	"private": true,
	"description": "Build tooling for HR Skills — validates, syncs, and packages HR skill definitions",
	"type": "module",
	"license": "MIT",
	"author": "Tuan Duc Tran",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tuanductran/hr-skills.git",
		"directory": "packages/hr-skills-build"
	},
	"keywords": [
		"hr",
		"human-resources",
		"skills",
		"ai-skills",
		"claude",
		"llm",
		"agents"
	],
	"scripts": {
		"validate": "bun src/validate.ts",
		"sync": "bun src/sync.ts",
		"test": "bun test",
		"dev": "bun --watch src/validate.ts",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@clack/prompts": "catalog:",
		"valibot": "catalog:",
		"skills-ref": "workspace:*",
		"yaml": "catalog:"
	}
}
