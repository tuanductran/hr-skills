{
	"compilerOptions": {
		"target": "ESNext",
		"lib": ["ESNext"],
		"moduleDetection": "force",
		"module": "Preserve",
		"moduleResolution": "bundler",
		"types": ["@types/bun"],
		"strict": true,
		"noFallthroughCasesInSwitch": true,
		"noEmit": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": true
	},
	"include": ["src", "test", "build.config.ts"],
	"exclude": ["node_modules", "dist"]
}
