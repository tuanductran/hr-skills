{
	"$schema": "https://turborepo.dev/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		},

		"dev": {
			"dependsOn": ["^dev"]
		},

		"typecheck": {},

		"test": {},

		"validate": {
			"cache": false
		},

		"catalog": {
			"cache": false
		},

		"sync": {
			"cache": false
		}
	}
}