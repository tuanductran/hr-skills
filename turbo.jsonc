{
	"$schema": "https://turborepo.dev/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**"]
		},

		"typecheck": {
			"dependsOn": ["^typecheck"]
		},

		"test": {
			"dependsOn": ["^test"]
		},

		"validate": {
			"cache": false
		},

		"catalog": {
			"cache": false
		},

		"sync": {
			"cache": false
		}
	}
}